OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
MONGODB_URI=mongodb://127.0.0.1:27017/unreel
PORT=3000
SITE_URL=https://www.unreeled.in
JWT_SECRET=replace_with_a_strong_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_API_BASE_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email_username
SMTP_PASS=your_email_password_or_app_password
SMTP_FROM="Unreel" <no-reply@unreeled.in>
MAIL_BRAND_NAME=Unreel
MAIL_BRAND_COLOR=#7c3aed
MAIL_LOGO_URL=https://www.unreeled.in/og-image.png
ENABLE_BROWSER_COOKIES=false
# Set to true only in local environments where Chrome/Edge/Firefox profiles exist.
# Keep false on hosted deployments (Render/Railway) to avoid irrelevant cookie-session errors.
INSTAGRAM_COOKIES_B64=
# Optional for production: base64-encoded Netscape cookies.txt exported from a logged-in Instagram browser session.
# Use this on hosted deployments where browser profile cookies are unavailable.
YTDLP_COOKIES_B64=
# Recommended for production: base64-encoded Netscape cookies.txt exported from a logged-in browser.
# This can help yt-dlp access YouTube Shorts and Instagram on hosted servers.

# How to get free API keys:
# 1. Groq (FREE): https://console.groq.com — free tier for Whisper + LLMs
# 2. OpenAI Whisper: https://platform.openai.com/api-keys — very cheap (~$0.006/min audio)
# 3. Tavily (FREE): https://tavily.com — free tier gives 1000 searches/month

# Also install yt-dlp:
# Windows: winget install yt-dlp
# Or download from: https://github.com/yt-dlp/yt-dlp/releases
